{
  "expo": {
    "name": "LabIA",
    "slug": "cardio-risk-calculator",
    "version": "1.0.0",
    "scheme": "labia",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "privacyPolicyUrl": "https://joaofay.github.io/labia-privacy/",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.drjuaum.labia",
      "privacyPolicyUrl": "https://joaofay.github.io/labia-privacy/"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.drjuaum.labia"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "privacyPolicyUrl": "https://joaofay.github.io/labia-privacy/",
      "eas": {
        "projectId": "8d010114-50a6-4e90-bcab-4b60fbec9fbc"
      }
    },
    "plugins": [
      "expo-font",
      [
        "@sentry/react-native",
        {
          "organization": "cfneves",
          "project": "labia"
        }
      ]
    ],
    "owner": "joaofay"
  }
}
